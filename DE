├── app/
│   ├── globals.css          # Global styles & CSS variables
│   ├── layout.tsx           # Root layout with SEO, theme, navigation
│   ├── page.tsx             # Main page composing all sections
│   ├── robots.ts            # SEO robots.txt
│   └── sitemap.ts           # SEO sitemap
├── components/
│   ├── layout/
│   │   ├── navbar.tsx       # Navigation bar
│   │   └── footer.tsx       # Footer
│   ├── providers/
│   │   └── theme-provider.tsx  # Dark/Light theme context
│   ├── sections/
│   │   ├── hero.tsx         # Hero section
│   │   ├── about.tsx        # About section
│   │   ├── expertise.tsx    # Core expertise grid
│   │   ├── projects.tsx     # Case studies with expand/collapse
│   │   ├── experience.tsx   # Career timeline
│   │   ├── testimonials.tsx # Client testimonials
│   │   ├── ai-assistant.tsx # Embedded AI chat assistant
│   │   ├── blog.tsx         # Blog preview cards
│   │   ├── resume.tsx       # Resume with download
│   │   └── contact.tsx      # Contact form & info
│   └── ui/
│       ├── animated-background.tsx  # Canvas particle animation
│       ├── nc-logo.tsx      # SVG logo component
│       └── section-wrapper.tsx  # Reusable section container
└── lib/
    ├── data.ts              # All site content & structured data
    └── utils.ts             # Tailwind merge utility
```

